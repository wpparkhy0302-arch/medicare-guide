---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import statesData from '../data/states.json';

const states = Object.entries(statesData)
  .map(([abbr, data]) => ({ abbr, name: data.name, slug: data.slug }))
  .sort((a, b) => a.name.localeCompare(b.name));

const topics = [
  { id: 'dental',      label: 'Dental',      icon: '🦷' },
  { id: 'vision',      label: 'Vision',      icon: '👁️' },
  { id: 'hearing-aids',label: 'Hearing Aids', icon: '👂' },
  { id: 'nursing-home',label: 'Nursing Home', icon: '🏥' },
];

const guideArticles = await getCollection('guides');
guideArticles.sort((a, b) =>
  new Date(b.data.dateModified).getTime() - new Date(a.data.dateModified).getTime()
);
---
<BaseLayout title="All Medicare Guides — US Medicare Guide" description="Browse Medicare guides and all 50 state coverage pages covering dental, vision, hearing aids, and nursing home benefits.">
  <div class="page-hero">
    <div class="container">
      <h1>Medicare Guides</h1>
      <p>In-depth guides and all 50 state coverage pages for dental, vision, hearing, and nursing home benefits.</p>
    </div>
  </div>

  <div class="page-body">
    <div class="container">

      <!-- Featured Guide Articles -->
      {guideArticles.length > 0 && (
        <section class="guides-section">
          <h2 class="section-heading">Coverage Guides</h2>
          <div class="guide-cards">
            {guideArticles.map(g => (
              <a class="guide-card" href={`/guides/${g.id}`}>
                <div class="guide-card-meta">
                  {g.data.category && <span class="guide-category">{g.data.category}</span>}
                  <span class="guide-date">{new Date(g.data.dateModified).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                </div>
                <div class="guide-title">{g.data.title}</div>
                <div class="guide-desc">{g.data.description}</div>
                <span class="guide-read">Read guide →</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <h2 class="section-heading">State Coverage Pages</h2>
      <div class="topic-chips">
        {topics.map(t => (
          <span class="chip">{t.icon} {t.label}</span>
        ))}
      </div>

      <div class="states-table">
        {states.map(s => (
          <a class="state-row" href={`/states/${s.slug}`}>
            <span class="state-abbr">{s.abbr}</span>
            <span class="state-name">{s.name}</span>
            <span class="state-links">
              {topics.map(t => (
                <span class="topic-tag">{t.icon}</span>
              ))}
            </span>
            <span class="arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .guides-section { margin-bottom: 2.5rem; }
  .section-heading { font-size: 1.15rem; font-weight: 700; color: #1a4fa0; margin-bottom: 1rem; }
  .guide-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
  .guide-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.25rem 1.4rem;
    background: #f0f7ff;
    border: 1.5px solid #bfdbfe;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.15s;
    color: inherit;
  }
  .guide-card:hover { border-color: #2563eb; background: #e0eeff; text-decoration: none; transform: translateY(-1px); }
  .guide-card-meta { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }
  .guide-category {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    background: #2563eb; color: white; padding: 0.15rem 0.6rem; border-radius: 10px;
  }
  .guide-date { font-size: 0.75rem; color: #64748b; }
  .guide-title { font-size: 0.97rem; font-weight: 700; color: #0f3578; line-height: 1.4; }
  .guide-desc { font-size: 0.83rem; color: #475569; line-height: 1.55; flex: 1; }
  .guide-read { font-size: 0.82rem; color: #2563eb; font-weight: 600; }
</style>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0f3578 0%, #2563eb 100%);
    color: white;
    padding: 2.5rem 1rem;
  }
  .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-hero p { opacity: 0.88; font-size: 1rem; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 1rem; }
  .page-body { padding: 2rem 1rem; }

  .topic-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .chip { padding: 0.35rem 0.85rem; background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 20px; font-size: 0.82rem; color: #1e40af; font-weight: 600; }

  .states-table { display: flex; flex-direction: column; gap: 0.5rem; }
  .state-row {
    display: grid;
    grid-template-columns: 48px 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .state-row:hover {
    background: #eff6ff;
    border-color: #2563eb;
    transform: translateX(2px);
    text-decoration: none;
  }
  .state-abbr { font-weight: 700; font-size: 0.9rem; color: #2563eb; }
  .state-name { font-size: 0.9rem; color: #1e293b; font-weight: 500; }
  .state-links { display: flex; gap: 0.4rem; font-size: 1rem; }
  .topic-tag { opacity: 0.6; }
  .state-row:hover .topic-tag { opacity: 1; }
  .arrow { color: #94a3b8; font-size: 1rem; transition: color 0.15s; }
  .state-row:hover .arrow { color: #2563eb; }
</style>
