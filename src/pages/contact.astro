---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — US Medicare Guide" description="Get in touch with US Medicare Guide for questions, corrections, or feedback.">
  <div class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Questions, corrections, or feedback? We'd love to hear from you.</p>
    </div>
  </div>

  <div class="page-body">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Get in Touch</h2>
          <p>US Medicare Guide is an independent informational resource. We welcome corrections, suggestions, and general inquiries.</p>

          <div class="info-card">
            <div class="info-icon">📧</div>
            <div>
              <strong>Email</strong>
              <p>contact@usmedicareguide.com</p>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">🕐</div>
            <div>
              <strong>Response Time</strong>
              <p>We typically respond within 2–3 business days.</p>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">🏥</div>
            <div>
              <strong>Medicare Help Line</strong>
              <p>For Medicare coverage questions, call <strong>1-800-MEDICARE</strong> (1-800-633-4227) — available 24/7.</p>
            </div>
          </div>
        </div>

        <div class="contact-form-wrap">
          <h2>Send a Message</h2>
          <form class="contact-form" netlify name="contact" method="POST">
            <div class="field">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" placeholder="Jane Smith" required />
            </div>
            <div class="field">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required />
            </div>
            <div class="field">
              <label for="subject">Subject</label>
              <select id="subject" name="subject">
                <option value="general">General Question</option>
                <option value="correction">Content Correction</option>
                <option value="suggestion">Suggestion</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Your message..." required></textarea>
            </div>
            <button type="submit" class="btn-submit">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0f3578 0%, #2563eb 100%);
    color: white;
    padding: 2.5rem 1rem;
  }
  .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-hero p { opacity: 0.88; font-size: 1rem; }
  .container { max-width: 1000px; margin: 0 auto; padding: 0 1rem; }
  .page-body { padding: 2.5rem 1rem; }

  .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2.5rem; }

  .contact-info h2, .contact-form-wrap h2 { font-size: 1.2rem; font-weight: 700; color: #1a4fa0; margin-bottom: 0.75rem; }
  .contact-info > p { font-size: 0.9rem; color: #475569; line-height: 1.6; margin-bottom: 1.25rem; }

  .info-card { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.9rem 1rem; background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 10px; margin-bottom: 0.75rem; }
  .info-icon { font-size: 1.3rem; flex-shrink: 0; }
  .info-card strong { display: block; font-size: 0.88rem; font-weight: 700; color: #1e293b; margin-bottom: 0.2rem; }
  .info-card p { font-size: 0.85rem; color: #475569; margin: 0; line-height: 1.5; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.3rem; }
  .field label { font-size: 0.85rem; font-weight: 600; color: #334155; }
  .field input, .field select, .field textarea {
    padding: 0.6rem 0.85rem;
    border: 1.5px solid #e2e8f0;
    border-radius: 7px;
    font-size: 0.9rem;
    color: #1e293b;
    background: white;
    font-family: inherit;
    transition: border-color 0.15s;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .field textarea { resize: vertical; }
  .btn-submit {
    padding: 0.7rem 1.5rem;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    width: fit-content;
  }
  .btn-submit:hover { background: #1a4fa0; }
</style>
