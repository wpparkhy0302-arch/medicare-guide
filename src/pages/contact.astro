---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — US Medicare Guide" description="Get in touch with US Medicare Guide for questions, corrections, or feedback.">
  <div class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Questions, corrections, or feedback? We'd love to hear from you.</p>
    </div>
  </div>

  <div class="page-body">
    <div class="container">

      <div class="email-highlight">
        <div class="email-icon">📧</div>
        <div class="email-body">
          <div class="email-label">Email us at</div>
          <a class="email-address" href="mailto:contact@usmedicareguide.com">contact@usmedicareguide.com</a>
          <div class="email-note">We typically respond within 2–3 business days.</div>
        </div>
      </div>

      <div class="info-grid">
        <div class="info-card">
          <div class="info-icon">✏️</div>
          <div>
            <strong>Content Corrections</strong>
            <p>Found outdated or inaccurate information? Please include the page URL and the specific correction in your email so we can review it promptly.</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">💡</div>
          <div>
            <strong>Suggestions &amp; Feedback</strong>
            <p>Have an idea for improving the site or a topic you'd like us to cover? We read every message and appreciate the input.</p>
          </div>
        </div>
        <div class="info-card">
          <div class="info-icon">🏥</div>
          <div>
            <strong>Medicare Coverage Questions</strong>
            <p>For personalized Medicare help, contact <strong>1-800-MEDICARE</strong> (1-800-633-4227) 24/7, or find your free state SHIP counselor at <a href="https://www.shiphelp.org" target="_blank" rel="noopener noreferrer">shiphelp.org</a>.</p>
          </div>
        </div>
      </div>

      <div class="disclaimer-box">
        <p>US Medicare Guide is an independent informational resource. We cannot provide personalized Medicare advice, plan recommendations, or enrollment assistance. For those needs, please contact <a href="https://www.medicare.gov/talk-to-someone" target="_blank" rel="noopener noreferrer">1-800-MEDICARE</a> or a licensed SHIP counselor.</p>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0f3578 0%, #2563eb 100%);
    color: white;
    padding: 2.5rem 1rem;
  }
  .page-hero h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin-bottom: 0.5rem; }
  .page-hero p { opacity: 0.88; font-size: 1rem; }
  .container { max-width: 760px; margin: 0 auto; padding: 0 1rem; }
  .page-body { padding: 2.5rem 1rem; }

  .email-highlight {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: #f0f7ff;
    border: 2px solid #bfdbfe;
    border-radius: 14px;
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .email-icon { font-size: 2rem; flex-shrink: 0; }
  .email-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; margin-bottom: 0.2rem; }
  .email-address {
    display: inline-block;
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a4fa0;
    text-decoration: none;
    word-break: break-all;
  }
  .email-address:hover { text-decoration: underline; }
  .email-note { font-size: 0.82rem; color: #64748b; margin-top: 0.35rem; }

  .info-grid { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 2rem; }
  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    background: #f8fafc;
    border: 1.5px solid #e2e8f0;
    border-radius: 10px;
  }
  .info-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
  .info-card strong { display: block; font-size: 0.9rem; font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; }
  .info-card p { font-size: 0.86rem; color: #475569; margin: 0; line-height: 1.55; }
  .info-card a { color: #2563eb; }

  .disclaimer-box {
    background: #fff8e1;
    border-left: 4px solid #f59e0b;
    border-radius: 6px;
    padding: 0.85rem 1.1rem;
  }
  .disclaimer-box p { font-size: 0.83rem; color: #78350f; line-height: 1.6; margin: 0; }
  .disclaimer-box a { color: #92400e; font-weight: 600; }

  @media (max-width: 480px) {
    .email-highlight { flex-direction: column; gap: 0.75rem; padding: 1.25rem; }
    .email-address { font-size: 1rem; }
  }
</style>
