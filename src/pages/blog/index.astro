---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import statesData from '../../data/states.json';

type TopicKey = 'dental' | 'vision' | 'hearing-aids' | 'nursing-home';

const TOPICS: Array<{ key: TopicKey; label: string; icon: string; color: string; bg: string; border: string; question: string }> = [
  { key: 'dental',       label: 'Dental',       icon: '🦷', color: '#0f7490', bg: '#ecfeff', border: '#a5f3fc', question: 'Does Medicare Cover Dental' },
  { key: 'vision',       label: 'Vision',       icon: '👁️', color: '#7c3aed', bg: '#f5f3ff', border: '#ddd6fe', question: 'Does Medicare Cover Vision' },
  { key: 'hearing-aids', label: 'Hearing Aids', icon: '👂', color: '#b45309', bg: '#fffbeb', border: '#fde68a', question: 'Does Medicare Cover Hearing Aids' },
  { key: 'nursing-home', label: 'Nursing Home', icon: '🏥', color: '#166534', bg: '#f0fdf4', border: '#bbf7d0', question: 'Does Medicare Cover Nursing Home' },
];

const states = Object.entries(statesData).map(([abbr, sd]: [string, any]) => ({
  abbr,
  name: sd.name as string,
  slug: sd.slug as string,
  dental:      (sd.dental?.coverage as string)      ?? 'Limited',
  vision:      (sd.vision?.coverage as string)      ?? 'Limited',
  hearingAids: (sd.hearingAids?.coverage as string) ?? 'Not Covered',
  nursingHome: (sd.nursingHome?.coverage as string) ?? 'Partial',
}));

const coverageBadge = (level: string) => {
  if (level === 'Comprehensive') return { cls: 'bg-green', label: 'Comprehensive' };
  if (level === 'Moderate')      return { cls: 'bg-blue',  label: 'Moderate' };
  if (level === 'Partial')       return { cls: 'bg-yellow', label: 'Partial' };
  if (level === 'Limited')       return { cls: 'bg-yellow', label: 'Limited' };
  return                                 { cls: 'bg-red',   label: 'Not Covered' };
};

const topicCoverage: Record<TopicKey, string> = {
  'dental':       'dental',
  'vision':       'vision',
  'hearing-aids': 'hearingAids',
  'nursing-home': 'nursingHome',
};
---

<BaseLayout
  title="Medicare Coverage Blog — All 50 States 2026"
  description="Does Medicare cover dental, vision, hearing aids, or nursing home care in your state? Find 2026 state-specific Medicare coverage guides for all 50 US states."
>
  <!-- Hero -->
  <div class="blog-index-hero">
    <div class="container">
      <h1>Medicare Coverage Guides — All 50 States 2026</h1>
      <p>Find state-specific answers to "Does Medicare cover dental / vision / hearing aids / nursing home?" — updated for 2026 with programs, costs, and enrollment tips.</p>
      <div class="hero-chips">
        {TOPICS.map(t => (
          <a href={`#${t.key}`} class="hero-chip" style={`background:${t.color};`}>
            {t.icon} {t.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="page-body">
    <div class="container">

      <AdSlot slot="5555555555" format="horizontal" />

      <!-- Stats bar -->
      <div class="stats-bar">
        <div class="stat-item"><strong>200</strong> State-Specific Guides</div>
        <div class="stat-item"><strong>50</strong> US States Covered</div>
        <div class="stat-item"><strong>4</strong> Medicare Topics</div>
        <div class="stat-item"><strong>2026</strong> Updated</div>
      </div>

      <!-- Topic sections -->
      {TOPICS.map((topic, ti) => (
        <section id={topic.key} class="topic-block" style={`--tc:${topic.color};--tb:${topic.bg};--te:${topic.border};`}>
          <div class="topic-header">
            <div class="topic-title">
              <span class="topic-icon">{topic.icon}</span>
              <div>
                <h2>{topic.question} in [State] 2026?</h2>
                <p class="topic-sub">Coverage guides for all 50 states — programs, costs, and tips.</p>
              </div>
            </div>
          </div>

          <div class="state-grid">
            {states.map(st => {
              const cvKey = topicCoverage[topic.key] as keyof typeof st;
              const cv = st[cvKey] as string;
              const badge = coverageBadge(cv);
              return (
                <a
                  href={`/blog/does-medicare-cover-${topic.key}-in-${st.slug}-2026`}
                  class="state-card"
                >
                  <div class="sc-top">
                    <span class="sc-abbr">{st.abbr}</span>
                    <span class={`sc-badge ${badge.cls}`}>{badge.label}</span>
                  </div>
                  <div class="sc-name">{st.name}</div>
                  <div class="sc-cta">Read Guide →</div>
                </a>
              );
            })}
          </div>

          {ti === 1 && <AdSlot slot="6666666666" format="horizontal" />}
        </section>
      ))}

      <AdSlot slot="7777777777" format="horizontal" />

      <!-- Bottom CTA -->
      <div class="bottom-cta">
        <h2>Need Personalized Medicare Help?</h2>
        <p>Your State Health Insurance Assistance Program (SHIP) offers free, unbiased Medicare counseling. Find your local SHIP at <a href="https://www.shiphelp.org" target="_blank" rel="noopener">shiphelp.org</a> or call <strong>1-800-633-4227</strong>.</p>
        <div class="cta-btns">
          <a href="https://www.shiphelp.org" target="_blank" rel="noopener" class="btn-primary">Find Free SHIP Help</a>
          <a href="https://www.medicare.gov/plan-compare" target="_blank" rel="noopener" class="btn-secondary">Compare Plans</a>
          <a href="/" class="btn-secondary">All State Guides</a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .blog-index-hero {
    background: linear-gradient(135deg, #0f3578 0%, #1a4fa0 100%);
    color: white; padding: 2.5rem 1rem;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
  .blog-index-hero h1 { font-size: clamp(1.4rem, 3vw, 2.1rem); font-weight: 800; margin-bottom: .6rem; }
  .blog-index-hero p  { opacity: .88; font-size: .95rem; max-width: 640px; line-height: 1.65; margin-bottom: 1.25rem; }
  .hero-chips { display: flex; gap: .5rem; flex-wrap: wrap; }
  .hero-chip {
    padding: .35rem 1rem; border-radius: 20px; color: white;
    font-size: .83rem; font-weight: 600; text-decoration: none; opacity: .92;
  }
  .hero-chip:hover { opacity: 1; text-decoration: none; }

  .page-body { padding: 2rem 0; }

  .stats-bar {
    display: flex; gap: .75rem; flex-wrap: wrap; justify-content: center;
    background: #f0f7ff; border: 1.5px solid #bfdbfe; border-radius: 12px;
    padding: 1rem 1.5rem; margin-bottom: 2rem;
  }
  .stat-item { font-size: .9rem; color: #1e40af; padding: .25rem .75rem; }
  .stat-item strong { font-size: 1.2rem; color: #0f3578; display: block; text-align: center; }

  /* Topic sections */
  .topic-block {
    margin-bottom: 3rem;
    background: var(--tb); border: 1.5px solid var(--te); border-radius: 16px; padding: 1.75rem;
  }
  .topic-header { margin-bottom: 1.5rem; }
  .topic-title { display: flex; align-items: flex-start; gap: 1rem; flex-wrap: wrap; }
  .topic-icon { font-size: 2.2rem; flex-shrink: 0; }
  .topic-title h2 { font-size: 1.3rem; font-weight: 800; color: var(--tc); margin-bottom: .2rem; }
  .topic-sub { font-size: .85rem; color: #475569; }

  /* State grid */
  .state-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
    gap: .65rem;
  }
  .state-card {
    background: white; border: 1.5px solid var(--te); border-radius: 10px;
    padding: .85rem .9rem; text-decoration: none; color: #1e293b;
    display: flex; flex-direction: column; gap: .3rem;
    transition: border-color .15s, box-shadow .15s;
  }
  .state-card:hover { border-color: var(--tc); box-shadow: 0 2px 8px rgba(0,0,0,.08); text-decoration: none; }
  .sc-top { display: flex; align-items: center; justify-content: space-between; gap: .3rem; }
  .sc-abbr { font-size: .78rem; font-weight: 800; color: var(--tc); letter-spacing: .03em; }
  .sc-badge {
    font-size: .67rem; font-weight: 700; padding: .1rem .45rem;
    border-radius: 10px; white-space: nowrap;
  }
  .bg-green  { background: #dcfce7; color: #166534; }
  .bg-blue   { background: #dbeafe; color: #1e40af; }
  .bg-yellow { background: #fef9c3; color: #854d0e; }
  .bg-red    { background: #fee2e2; color: #991b1b; }
  .sc-name { font-size: .88rem; font-weight: 600; color: #1e293b; line-height: 1.3; }
  .sc-cta  { font-size: .78rem; color: var(--tc); font-weight: 600; margin-top: .1rem; }

  /* Bottom CTA */
  .bottom-cta {
    background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 16px;
    padding: 2rem; text-align: center; margin-top: 1rem;
  }
  .bottom-cta h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: .6rem; }
  .bottom-cta p  { font-size: .92rem; color: #475569; max-width: 580px; margin: 0 auto 1.25rem; line-height: 1.65; }
  .cta-btns { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    padding: .6rem 1.4rem; background: #2563eb; color: white;
    border-radius: 8px; font-size: .9rem; font-weight: 600; text-decoration: none;
  }
  .btn-primary:hover { background: #1a4fa0; text-decoration: none; }
  .btn-secondary {
    padding: .6rem 1.4rem; background: white; color: #2563eb;
    border: 1.5px solid #2563eb; border-radius: 8px; font-size: .9rem; font-weight: 600; text-decoration: none;
  }
  .btn-secondary:hover { background: #eff6ff; text-decoration: none; }
</style>
